{
    "$schema": "https://docs.openclaw.ai/schemas/plugin.json",
    "id": "volcengine-asr",
    "name": "Volcengine ASR",
    "description": "拦截语音消息并通过火山引擎 Seed-ASR 转写为文本。",
    "configSchema": {
        "type": "object",
        "properties": {
            "VOLC_API_KEY": {
                "type": "string",
                "description": "火山引擎 API Key"
            },
            "VOLC_RESOURCE_ID": {
                "type": "string",
                "description": "火山引擎 Seed-ASR 模型 Resource ID",
                "default": "volc.seedasr.auc"
            },
            "S3_ENDPOINT": {
                "type": "string",
                "description": "S3 兼容存储端点 URL"
            },
            "S3_ACCESS_KEY_ID": {
                "type": "string",
                "description": "S3 Access Key ID"
            },
            "S3_SECRET_ACCESS_KEY": {
                "type": "string",
                "description": "S3 Secret Access Key"
            },
            "S3_BUCKET": {
                "type": "string",
                "description": "S3 Bucket 名称",
                "default": "volcengine-asr"
            },
            "S3_REGION": {
                "type": "string",
                "description": "S3 区域",
                "default": "auto"
            },
            "S3_PUBLIC_URL": {
                "type": "string",
                "description": "S3 自定义公开域名 (可选)"
            }
        },
        "required": [
            "VOLC_API_KEY",
            "S3_ENDPOINT",
            "S3_ACCESS_KEY_ID",
            "S3_SECRET_ACCESS_KEY"
        ]
    }
}